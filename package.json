{
  "name": "npm-package-typescript-template",
  "version": "1.0.0-alpha",
  "description": "npm-package-typescript-template",
  "author": "Mark <mark@remarkablemark.org> (https://remarkablemark.org)",
  "main": "./cjs/index.js",
  "scripts": {
    "build": "npm run build:cjs && npm run build:umd",
    "build:cjs": "tsc",
    "build:umd": "rollup --config --failAfterWarnings",
    "build:watch": "tsc --watch",
    "clean": "rm -rf cjs coverage docs umd",
    "docs": "typedoc",
    "docs:watch": "npm run docs -- --watch",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "lint:package": "publint",
    "lint:tsc": "tsc --noEmit",
    "prepare": "husky",
    "prepublishOnly": "npm run lint && npm run lint:tsc && npm run test:ci && npm run clean && npm run build",
    "test": "vitest run",
    "test:ci": "npm run build:cjs && CI=true npm test -- --color",
    "test:watch": "vitest --coverage.enabled=false"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/remarkablemark/npm-package-typescript-template.git"
  },
  "bugs": {
    "url": "https://github.com/remarkablemark/npm-package-typescript-template/issues"
  },
  "keywords": [
    "npm-package-typescript-template"
  ],
  "devDependencies": {
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/compat": "2.0.2",
    "@eslint/eslintrc": "3.3.3",
    "@eslint/js": "9.39.2",
    "@rollup/plugin-commonjs": "29.0.0",
    "@rollup/plugin-terser": "0.4.4",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "25.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "9.39.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-tsdoc": "0.5.0",
    "globals": "17.3.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.1",
    "publint": "0.3.17",
    "rollup": "4.57.1",
    "tslib": "2.8.1",
    "typedoc": "0.28.16",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "^4.0.18"
  },
  "files": [
    "cjs/",
    "src/",
    "umd/"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/remarkablemark"
    }
  ],
  "license": "MIT"
}
