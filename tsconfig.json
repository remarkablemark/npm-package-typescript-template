{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["es2020"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "types": ["vitest/globals"],
    "noEmit": true
  },
  "include": ["__tests__", "src", "*.mjs", "*.mts", "*.ts"]
}
